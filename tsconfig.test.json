{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "strict": true,
    "types": ["node", "vitest/globals"]
  },
  "include": ["src/**/__tests__/**/*.ts", "src/data/**/*.ts", "src/lib/**/*.ts"]
}
